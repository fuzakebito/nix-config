{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_mcps": [
    "websearch"
  ],
  "disabled_hooks": [
    "context-window-monitor",
    "keyword-detector"
  ],
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "librarian": {
      "model": "zai-coding-plan/glm-5.2"
    },
    "explore": {
      "model": "zai-coding-plan/glm-5.2"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "xhigh"
    },
    "metis": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "xhigh"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "zai-coding-plan/glm-5.2"
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5",
      "variant": "low"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "quick": {
      "model": "zai-coding-plan/glm-5.2"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "coding": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "medium"
    },
    "writing": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "medium"
    },
    "brain-1": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "brain-2": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "xhigh"
    },
    "brain-3": {
      "model": "zai-coding-plan/glm-5.2"
    }
  },
  "tmux": {
    "enabled": false,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  }
}
