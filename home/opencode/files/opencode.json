{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-claude-auth@latest"
  ],
  "lsp": {
    "efm-langserver": {
      "command": [
        "efm-langserver"
      ],
      "extensions": [
        ".md"
      ],
      "initialization": {
        "documentFormatting": true,
        "documentRangeFormatting": true,
        "hover": true,
        "documentSymbol": true,
        "codeAction": true,
        "completion": true
      }
    }
  },
  "agent": {},
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:e4b": {
          "name": "gemma4:e4b"
        }
      }
    }
  }
}
